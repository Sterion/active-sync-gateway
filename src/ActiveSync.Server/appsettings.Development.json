{
	"Serilog": {
		"MinimumLevel": {
			"Default": "Debug",
			"Override": {
				"Microsoft.AspNetCore": "Warning",
				"Microsoft.EntityFrameworkCore": "Warning"
			}
		}
	},
	"ActiveSync": {
		"Imap": {
			"Host": "localhost",
			"Port": 143,
			"UseSsl": false
		},
		"Smtp": {
			"Host": "localhost",
			"Port": 587,
			"UseSsl": false
		},
		"CalDav": {
			"BaseUrl": "http://localhost:5232",
			"HomeSetPath": ""
		},
		"CardDav": {
			"BaseUrl": "http://localhost:5232",
			"HomeSetPath": ""
		},
		"ReadOnly": false,
		"Database": {
			"Provider": "Sqlite",
			"ConnectionString": "Data Source=activesync.db"
		},
		"Encryption": {
			"AllowPlaintext": true
		}
	}

}

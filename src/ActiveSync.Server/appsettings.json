{
	"Serilog": {
		"MinimumLevel": {
			"Default": "Information",
			"Override": {
				"Microsoft.AspNetCore": "Warning",
				"Microsoft.EntityFrameworkCore": "Warning"
			}
		}
	},
	"AllowedHosts": "*",
	"Kestrel": {
		"Endpoints": {
			"Http": {
				"Url": "http://0.0.0.0:5080"
			}
		}
	},
	"ActiveSync": {
		"Backends": {
			"MailStore": {
				"Provider": "imap",
				"Host": "imap.example.com",
				"Port": 993,
				"UseSsl": true
			},
			"MailSubmit": {
				"Provider": "smtp",
				"Host": "smtp.example.com",
				"Port": 465,
				"UseSsl": true
			}
		},
		"ReadOnly": false,
		"Database": {
			"Provider": "Sqlite",
			"ConnectionString": "Data Source=activesync.db"
		},
		"Encryption": {
			"Key": "",
			"KeyFile": "",
			"AllowPlaintext": false
		},
		"Eas": {
			"MinHeartbeatSeconds": 60,
			"MaxHeartbeatSeconds": 1770,
			"DavPollSeconds": 60,
			"MaxWindowSize": 512,
			"DefaultWindowSize": 100,
			"SessionIdleMinutes": 15,
			"UseImapIdle": true,
			"WatchdogSeconds": 0
		}
	}
}

{
	"Serilog": {
		"MinimumLevel": {
			"Default": "Information",
			"Override": {
				"Microsoft.AspNetCore": "Warning",
				"Microsoft.EntityFrameworkCore": "Warning"
			}
		}
	},
	"AllowedHosts": "*",
	"Kestrel": {
		"Endpoints": {
			"Http": {
				"Url": "http://0.0.0.0:5080"
			}
		}
	},
	"ActiveSync": {
		"_comment": "No mail backend ships by default — the gateway starts UNCONFIGURED and is set up with 'eas config set ActiveSync:Backends:MailStore:...' (and MailSubmit). Only the bootstrap Database/Encryption sections live here; all other settings default in code and are overridden from the database.",
		"ReadOnly": false,
		"Database": {
			"Provider": "Sqlite",
			"ConnectionString": "Data Source=activesync.db"
		},
		"Encryption": {
			"Key": "",
			"KeyFile": "",
			"AllowPlaintext": false
		},
		"Eas": {
			"MinHeartbeatSeconds": 60,
			"MaxHeartbeatSeconds": 1770,
			"DavPollSeconds": 60,
			"MaxWindowSize": 512,
			"DefaultWindowSize": 100,
			"SessionIdleMinutes": 15,
			"UseImapIdle": true,
			"WatchdogSeconds": 0
		}
	}
}
